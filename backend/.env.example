PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ragwiki?sslmode=require
REDIS_URL=https://xxx.upstash.io


# Frontend URL
FRONTEND_URL=http://localhost:5173

# OpenAI secrets
OPENROUTER_API_KEY=sk-...
OPENROUTER_MODEL=gpt-4o-mini
OPENROUTER_EMBED_MODEL=text-embedding-3-small

# Embedding controls
EMBED_DIMENSIONS=2048
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
MAX_FILE_SIZE_MB=20

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LLM_RATE_LIMIT_WINDOW_MS=3600000
LLM_RATE_LIMIT_MAX=10

# Caching
CACHE_TTL_QUERY=3600
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_RETRIEVAL=1800